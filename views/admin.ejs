<%- include('layout-top') %>
<div class="card">
  <h2>Kayıt Formu Alan Kuralları</h2>
  <p class="muted">Hangi alanların zorunlu olduğunu ve isteğe bağlı biçim desenini (regex) buradan belirleyin.
    Desen örneği: <code>^[A-Z0-9]{7,12}$</code> — boş bırakılırsa biçim kontrolü yapılmaz.</p>
  <form method="post" action="/admin/kurallar">
    <table>
      <thead>
        <tr><th>Alan</th><th>Zorunlu</th><th>Biçim deseni (regex, opsiyonel)</th></tr>
      </thead>
      <tbody>
        <% ruleRows.forEach(r => { %>
        <tr>
          <td><%= r.label %></td>
          <td class="center">
            <input type="checkbox" name="required_<%= r.field_name %>" class="checkbox"
                   <%= r.required ? 'checked' : '' %>>
          </td>
          <td>
            <% if (r.field_name === 'personnel_id') { %>
              <span class="muted">— (listeden seçilir)</span>
            <% } else { %>
              <input name="pattern_<%= r.field_name %>" value="<%= r.pattern || '' %>" placeholder="örn: ^[A-Z0-9]{5,15}$">
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <br>
    <button type="submit">Kuralları Kaydet</button>
  </form>
</div>

<div class="grid-2">
  <div class="card">
    <h2>CSV ile Personel Yükle</h2>
    <p class="muted">Format: <code>Numara;Ad Soyad;Eski PC Adı;Yeni PC Adı;Departman;Desktop;Eski PC Seri No;Yeni PC Seri No</code> — noktalı virgül veya virgül ayraçlı, başlık satırı opsiyonel. Boş alanlar yüklemeyi durdurmaz; ad soyadı boş satırlar atlanır. <strong>Numara</strong> boş bırakılırsa tablodaki son numaradan otomatik artar (boş tabloda 1'den başlar); Numara sütunu olmayan eski dosyalar da yüklenebilir. Desktop sütununa cihaz tipi <code>D</code> (Desktop), <code>N</code> (Notebook) veya <code>V</code> (VDI) yazılır; boş/tanımsız Notebook sayılır (eski <code>1</code>=Desktop, <code>0</code>=Notebook de kabul edilir). Mevcut kayıtlar atlanır.</p>
    <form method="post" action="/admin/import" enctype="multipart/form-data">
      <input type="file" name="csv" accept=".csv,text/csv" required>
      <button type="submit">Yükle</button>
    </form>
  </div>

  <div class="card">
    <h2>Tekil Personel Ekle</h2>
    <form method="post" action="/admin/personel">
      <label>Numara <small>(boş bırakılırsa sıradaki numara verilir)</small>
        <input name="seq_no" type="number" min="1" inputmode="numeric">
      </label>
      <label>Ad Soyad <span class="req">*</span>
        <input name="full_name" required>
      </label>
      <label>Eski PC Adı
        <input name="old_pc_name">
      </label>
      <label>Yeni PC Adı
        <input name="new_pc_name">
      </label>
      <label>Departman
        <input name="department">
      </label>
      <label>Eski PC Seri No
        <input name="old_pc_serial" style="text-transform: uppercase">
      </label>
      <label>Yeni PC Seri No
        <input name="new_pc_serial" style="text-transform: uppercase">
      </label>
      <fieldset class="device-type">
        <legend>Cihaz Tipi</legend>
        <label class="radio-inline"><input type="radio" name="desktop" value="D"> Desktop</label>
        <label class="radio-inline"><input type="radio" name="desktop" value="N" checked> Notebook</label>
        <label class="radio-inline"><input type="radio" name="desktop" value="V"> VDI</label>
      </fieldset>
      <button type="submit">Ekle</button>
    </form>
  </div>

  <div class="card">
    <h2>Teknisyen Hesabı Ekle</h2>
    <form method="post" action="/admin/kullanici">
      <label>Kullanıcı adı <span class="req">*</span>
        <input name="username" required autocomplete="off">
      </label>
      <label>Şifre <span class="req">*</span> <small>(en az 8 karakter)</small>
        <input type="password" name="password" required minlength="8" autocomplete="new-password">
      </label>
      <label>Rol
        <select name="role">
          <option value="tech">Teknisyen</option>
          <option value="admin">Admin</option>
        </select>
      </label>
      <button type="submit">Ekle</button>
    </form>
    <h3>Mevcut hesaplar</h3>
    <ul class="plain-list">
      <% techs.forEach(t => { %>
        <li><%= t.username %> <span class="badge"><%= t.role %></span></li>
      <% }) %>
    </ul>
  </div>
</div>

<div class="card">
  <h2>Personel Listesi (<%= personnel.length %>)</h2>
  <table>
    <thead>
      <tr><th>Numara</th><th>Ad Soyad</th><th>Eski PC Adı</th><th>Yeni PC Adı</th><th>Departman</th><th>Cihaz Tipi</th><th>Eski Seri</th><th>Yeni Seri</th><th></th></tr>
    </thead>
    <tbody>
      <% personnel.forEach(p => { %>
      <tr>
        <td><%= p.seq_no %></td>
        <td><%= p.full_name %></td>
        <td><%= p.old_pc_name || '-' %></td>
        <td><%= p.new_pc_name || '-' %></td>
        <td><%= p.department || '-' %></td>
        <td class="center"><%= { D: 'Desktop', N: 'Notebook', V: 'VDI' }[p.desktop] || '' %></td>
        <td><code><%= p.old_pc_serial || '-' %></code></td>
        <td><code><%= p.new_pc_serial || '-' %></code></td>
        <td>
          <form method="post" action="/admin/personel/<%= p.id %>/sil" class="inline"
                onsubmit="return confirm('<%= p.full_name %> silinsin mi?')">
            <button class="link-btn danger">Sil</button>
          </form>
        </td>
      </tr>
      <% }) %>
      <% if (personnel.length === 0) { %>
      <tr><td colspan="9" class="muted center">Personel listesi boş. Yukarıdan CSV yükleyin.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<%- include('layout-bottom') %>
