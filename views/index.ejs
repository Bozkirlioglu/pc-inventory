<%- include('layout-top') %>
<div class="card card-narrow">
  <h1>Yeni Kurulum Kaydı</h1>
  <form method="post" action="/kayit">
    <label>Kullanıcı <% if (rules.personnel_id.required) { %><span class="req">*</span><% } %>
      <input list="personnel-list" id="personnel-search" placeholder="İsim yazarak arayın..."
             autocomplete="off" <% if (rules.personnel_id.required) { %>required<% } %>>
      <datalist id="personnel-list">
        <% personnel.forEach(p => { %>
          <option data-id="<%= p.id %>" data-newpcname="<%= p.new_pc_name || '' %>"
                  data-oldserial="<%= p.old_pc_serial || '' %>"
                  data-desktop="<%= p.desktop ? 1 : 0 %>" data-newserial="<%= p.new_pc_serial || '' %>"
                  value="<%= p.full_name %><%= p.old_pc_name ? ' — ' + p.old_pc_name : '' %>"></option>
        <% }) %>
      </datalist>
      <input type="hidden" name="personnel_id" id="personnel-id">
    </label>
    <label>Yeni PC Adı
      <input id="new-pcname" readonly placeholder="Kullanıcı seçince otomatik dolar" class="readonly">
    </label>
    <label>Eski PC Seri No <% if (rules.old_pc_serial.required) { %><span class="req">*</span><% } %>
      <div class="input-with-btn">
        <input name="old_pc_serial" id="old-serial" placeholder="Elle girin veya metin okuyun"
               style="text-transform: uppercase" <% if (rules.old_pc_serial.required) { %>required<% } %>>
        <button type="button" id="ocr-start" title="Kameradan metin oku">📷 Metin Oku</button>
      </div>
    </label>
    <label>Yeni PC Seri No <% if (rules.new_pc_serial.required) { %><span class="req">*</span><% } %>
      <div class="input-with-btn">
        <input name="new_pc_serial" id="new-serial" placeholder="Elle girin veya okutun"
               style="text-transform: uppercase" <% if (rules.new_pc_serial.required) { %>required<% } %>>
        <button type="button" class="scan-btn" data-target="new-serial" title="Barkod okut">📷 Okut</button>
      </div>
    </label>
    <div id="scanner-box" hidden>
      <p class="muted center" id="scan-target-label"></p>
      <div id="scanner"></div>
      <p class="muted center" id="scan-status">Kamera başlatılıyor...</p>
      <button type="button" id="scan-cancel" class="btn-secondary btn-block">İptal</button>
    </div>
    <div id="ocr-box" hidden>
      <p class="muted center" id="ocr-status">Kamera başlatılıyor...</p>
      <div id="ocr-frame">
        <video id="ocr-video" autoplay playsinline muted></video>
        <div class="ocr-shade ocr-shade-top"></div>
        <div class="ocr-shade ocr-shade-bottom"></div>
        <div class="ocr-guide"></div>
      </div>
      <canvas id="ocr-canvas" hidden></canvas>
      <div class="action-row">
        <button type="button" id="ocr-read" class="btn-secondary">Oku</button>
        <button type="button" id="ocr-torch" class="btn-secondary" hidden>🔦 Işık</button>
        <button type="button" id="ocr-cancel" class="btn-secondary">İptal</button>
      </div>
    </div>
    <label class="checkbox-label">
      <input type="checkbox" name="desktop" id="desktop" class="checkbox" value="1"> Desktop
    </label>
    <label>#TODO <% if (rules.todo && rules.todo.required) { %><span class="req">*</span><% } else { %><small>(opsiyonel)</small><% } %>
      <textarea name="todo" rows="3" placeholder="Yapılacaklar..." <% if (rules.todo && rules.todo.required) { %>required<% } %>></textarea>
    </label>
    <label>Not <% if (rules.notes.required) { %><span class="req">*</span><% } else { %><small>(opsiyonel)</small><% } %>
      <input name="notes" placeholder="Ek bilgi..." <% if (rules.notes.required) { %>required<% } %>>
    </label>
    <button type="submit">Kaydet</button>
  </form>
  <% if (personnel.length === 0) { %>
    <p class="muted">Henüz personel listesi yüklenmemiş. <% if (user.role === 'admin') { %><a href="/admin">Yönetim</a> sayfasından CSV import edin.<% } else { %>Yöneticinizle iletişime geçin.<% } %></p>
  <% } %>
</div>
<script src="/vendor/html5-qrcode/html5-qrcode.min.js"></script>
<script src="/vendor/tesseract.js/dist/tesseract.min.js"></script>
<script>
  const search = document.getElementById('personnel-search');
  const hiddenId = document.getElementById('personnel-id');
  const newPcName = document.getElementById('new-pcname');
  const oldSerialInput = document.getElementById('old-serial');
  const newSerialInput = document.getElementById('new-serial');
  const desktopCb = document.getElementById('desktop');
  const formCard = document.querySelector('.card');
  const options = document.querySelectorAll('#personnel-list option');

  // Desktop işaretliyse arka plan yeşile döner
  function updateDesktopBg() {
    const bg = desktopCb.checked ? '#77DD77' : '';
    document.body.style.background = bg;
    formCard.style.background = bg;
  }
  desktopCb.addEventListener('change', updateDesktopBg);

  search.addEventListener('input', () => {
    hiddenId.value = '';
    newPcName.value = '';
    oldSerialInput.value = '';
    newSerialInput.value = '';
    for (const opt of options) {
      if (opt.value === search.value) {
        hiddenId.value = opt.dataset.id;
        newPcName.value = opt.dataset.newpcname;
        // Personelle önceden yüklenmiş alanlar formu doldurur
        desktopCb.checked = opt.dataset.desktop === '1';
        updateDesktopBg();
        if (opt.dataset.oldserial) oldSerialInput.value = opt.dataset.oldserial;
        if (opt.dataset.newserial) newSerialInput.value = opt.dataset.newserial;
        break;
      }
    }
  });

  document.querySelector('form').addEventListener('submit', e => {
    // Kullanıcı alanına bir şey yazılmış ama listeden eşleşmemişse engelle;
    // boş bırakmak (kural zorunlu demiyorsa) serbest.
    if (search.value.trim() && !hiddenId.value) {
      e.preventDefault();
      alert('Lütfen listeden geçerli bir kullanıcı seçin veya alanı boş bırakın.');
    }
  });

  // --- Barkod okuma (cep telefonu kamerası) — hedef alana yazar ---
  const scannerBox = document.getElementById('scanner-box');
  const scanStatus = document.getElementById('scan-status');
  const scanTargetLabel = document.getElementById('scan-target-label');
  const scanButtons = document.querySelectorAll('.scan-btn');
  let scanner = null;

  async function stopScanner() {
    if (scanner) {
      try { await scanner.stop(); scanner.clear(); } catch (e) {}
      scanner = null;
    }
    scannerBox.hidden = true;
    scanButtons.forEach(b => b.disabled = false);
  }

  scanButtons.forEach(btn => btn.addEventListener('click', async () => {
    if (!window.isSecureContext) {
      alert('Kamera yalnızca HTTPS (güvenli bağlantı) üzerinden kullanılabilir.');
      return;
    }
    if (typeof Html5Qrcode === 'undefined') {
      alert('Barkod kütüphanesi yüklenemedi.');
      return;
    }
    await stopScanner(); // önceki oturum açıksa kapat
    const target = document.getElementById(btn.dataset.target);
    scanButtons.forEach(b => b.disabled = true);
    scannerBox.hidden = false;
    scanTargetLabel.textContent = btn.closest('label') ? btn.closest('label').textContent.trim().split('\n')[0] : '';
    scanStatus.textContent = 'Kamera başlatılıyor...';

    scanner = new Html5Qrcode('scanner', {
      formatsToSupport: [
        Html5QrcodeSupportedFormats.CODE_128,
        Html5QrcodeSupportedFormats.CODE_39,
        Html5QrcodeSupportedFormats.CODE_93,
        Html5QrcodeSupportedFormats.EAN_13,
        Html5QrcodeSupportedFormats.EAN_8,
        Html5QrcodeSupportedFormats.UPC_A,
        Html5QrcodeSupportedFormats.UPC_E,
        Html5QrcodeSupportedFormats.ITF,
        Html5QrcodeSupportedFormats.QR_CODE,
        Html5QrcodeSupportedFormats.DATA_MATRIX
      ]
    });

    try {
      await scanner.start(
        { facingMode: 'environment' }, // arka kamera
        { fps: 10, qrbox: { width: 280, height: 140 } }, // yatay kutu: 1D barkod için
        decoded => {
          target.value = decoded.trim().toUpperCase();
          if (navigator.vibrate) navigator.vibrate(100);
          stopScanner();
        },
        () => {} // kare başına okunamama normal, sessiz geç
      );
      scanStatus.textContent = 'Barkodu çerçeveye hizalayın';
    } catch (err) {
      scanStatus.textContent = 'Kamera açılamadı: ' + (err.message || err);
      scanButtons.forEach(b => b.disabled = false);
    }
  }));

  document.getElementById('scan-cancel').addEventListener('click', stopScanner);

  // --- Eski seri no için OCR (kamera görüntüsünden metin okuma) ---
  const ocrBox = document.getElementById('ocr-box');
  const ocrStatus = document.getElementById('ocr-status');
  const ocrVideo = document.getElementById('ocr-video');
  const ocrCanvas = document.getElementById('ocr-canvas');
  const ocrStart = document.getElementById('ocr-start');
  const ocrRead = document.getElementById('ocr-read');
  const ocrTorch = document.getElementById('ocr-torch');
  const ocrCancel = document.getElementById('ocr-cancel');
  let ocrStream = null;
  let ocrWorker = null;

  async function stopOcr() {
    if (ocrStream) {
      ocrStream.getTracks().forEach(track => track.stop());
      ocrStream = null;
    }
    ocrVideo.srcObject = null;
    ocrBox.hidden = true;
    ocrStart.disabled = false;
    ocrRead.disabled = true;
    ocrTorch.hidden = true;
    ocrTorch.dataset.on = '0';
  }

  function normalizeSerial(text) {
    const cleaned = String(text || '')
      .toUpperCase()
      .replace(/\b(SERIAL|SERIALNO|SERIALNUMBER|SERI|SERI NO|S\/N|SN)\b/g, ' ');
    const candidates = cleaned
      .split(/\s+/)
      .map(part => part.replace(/[^A-Z0-9\-_/]/g, ''))
      .filter(part => /[A-Z0-9]/.test(part) && part.length >= 4)
      .sort((a, b) => b.length - a.length);
    if (candidates[0]) return candidates[0];
    const compact = cleaned.replace(/[^A-Z0-9\-_/]/g, '');
    return compact.length >= 4 ? compact : '';
  }

  function histPercentile(hist, total, p) {
    const target = total * p;
    let cum = 0;
    for (let i = 0; i < 256; i++) {
      cum += hist[i];
      if (cum >= target) return i;
    }
    return 255;
  }

  // Kılavuz bandını kırpar, gri tona çevirir ve %1-%99 persentil aralığına
  // kontrast gerer (tek bir parlama noktası germeyi bozmasın diye min/max değil).
  function captureOcrFrame() {
    const videoWidth = ocrVideo.videoWidth;
    const videoHeight = ocrVideo.videoHeight;
    const source = {
      x: Math.round(videoWidth * 0.05),
      y: Math.round(videoHeight * 0.40),
      width: Math.round(videoWidth * 0.90),
      height: Math.round(videoHeight * 0.20)
    };
    // OCR girişi ~1600 px genişlikte olsun; düşük çözünürlüklü kamerada daha çok büyüt
    const scale = Math.min(4, Math.max(1.5, 1600 / source.width));
    ocrCanvas.width = Math.round(source.width * scale);
    ocrCanvas.height = Math.round(source.height * scale);
    const ctx = ocrCanvas.getContext('2d', { willReadFrequently: true });
    ctx.drawImage(ocrVideo, source.x, source.y, source.width, source.height, 0, 0, ocrCanvas.width, ocrCanvas.height);

    const image = ctx.getImageData(0, 0, ocrCanvas.width, ocrCanvas.height);
    const total = ocrCanvas.width * ocrCanvas.height;
    const gray = new Uint8ClampedArray(total);
    const hist = new Uint32Array(256);
    for (let i = 0, j = 0; j < total; i += 4, j++) {
      const g = Math.round(image.data[i] * 0.299 + image.data[i + 1] * 0.587 + image.data[i + 2] * 0.114);
      gray[j] = g;
      hist[g]++;
    }
    const lo = histPercentile(hist, total, 0.01);
    const hi = Math.max(lo + 1, histPercentile(hist, total, 0.99));
    for (let j = 0; j < total; j++) {
      gray[j] = (gray[j] - lo) * 255 / (hi - lo); // Uint8ClampedArray 0-255'e kırpar
    }
    return { ctx, image, gray, total };
  }

  // Gri değerleri (istenirse bir dönüşümden geçirip) canvas'a basar, canvas'ı döndürür.
  function paintOcrFrame(frame, transform) {
    for (let j = 0, i = 0; j < frame.total; j++, i += 4) {
      const v = transform ? transform(frame.gray[j]) : frame.gray[j];
      frame.image.data[i] = v;
      frame.image.data[i + 1] = v;
      frame.image.data[i + 2] = v;
    }
    frame.ctx.putImageData(frame.image, 0, 0);
    return ocrCanvas;
  }

  // Otsu eşiği: sınıflar arası varyansı maksimize eden gri değer
  function otsuThreshold(frame) {
    const hist = new Uint32Array(256);
    for (let j = 0; j < frame.total; j++) hist[frame.gray[j]]++;
    let sum = 0;
    for (let i = 0; i < 256; i++) sum += i * hist[i];
    let sumB = 0, wB = 0, maxVar = 0, threshold = 127;
    for (let i = 0; i < 256; i++) {
      wB += hist[i];
      if (!wB) continue;
      const wF = frame.total - wB;
      if (!wF) break;
      sumB += i * hist[i];
      const mB = sumB / wB, mF = (sum - sumB) / wF;
      const between = wB * wF * (mB - mF) * (mB - mF);
      if (between > maxVar) { maxVar = between; threshold = i; }
    }
    return threshold;
  }

  async function getOcrWorker() {
    if (ocrWorker) return ocrWorker;
    ocrStatus.textContent = 'OCR motoru hazırlanıyor...';
    ocrWorker = await Tesseract.createWorker('eng', 1, {
      workerPath: '/vendor/tesseract.js/dist/worker.min.js',
      corePath: '/vendor/tesseract-core',
      langPath: '/vendor/tessdata/4.0.0/',
      logger: message => {
        if (message.status === 'recognizing text') {
          ocrStatus.textContent = `Metin okunuyor... %${Math.round(message.progress * 100)}`;
        }
      }
    });
    await ocrWorker.setParameters({
      tessedit_char_whitelist: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_/ ',
      tessedit_pageseg_mode: Tesseract.PSM.SINGLE_LINE,
      preserve_interword_spaces: '1'
    });
    return ocrWorker;
  }

  ocrStart.addEventListener('click', async () => {
    if (!window.isSecureContext) {
      alert('Kamera yalnızca HTTPS (güvenli bağlantı) üzerinden kullanılabilir.');
      return;
    }
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      alert('Bu tarayıcı kamera erişimini desteklemiyor.');
      return;
    }
    if (typeof Tesseract === 'undefined') {
      alert('OCR kütüphanesi yüklenemedi.');
      return;
    }
    await stopScanner();
    await stopOcr();
    ocrStart.disabled = true;
    ocrRead.disabled = true;
    ocrBox.hidden = false;
    ocrStatus.textContent = 'Kamera başlatılıyor...';
    try {
      // Yüksek çözünürlük şart: varsayılan 640x480'de etiket yazısı okunamayacak kadar küçük kalıyor
      ocrStream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: { ideal: 'environment' },
          width: { ideal: 1920 },
          height: { ideal: 1080 },
          advanced: [{ focusMode: 'continuous' }] // desteklenmeyen cihazlar yok sayar
        },
        audio: false
      });
      ocrVideo.srcObject = ocrStream;
      await new Promise(resolve => {
        if (ocrVideo.videoWidth) return resolve();
        ocrVideo.onloadedmetadata = () => resolve();
      });
      const track = ocrStream.getVideoTracks()[0];
      const caps = track.getCapabilities ? track.getCapabilities() : {};
      ocrTorch.hidden = !caps.torch;
      ocrTorch.dataset.on = '0';
      ocrRead.disabled = false;
      ocrStatus.textContent = 'Eski PC seri numarasını yatay ve net şekilde ortalayın, sonra Oku düğmesine basın.';
    } catch (err) {
      ocrStatus.textContent = 'Kamera açılamadı: ' + (err.message || err);
      ocrStart.disabled = false;
    }
  });

  ocrRead.addEventListener('click', async () => {
    if (!ocrStream || !ocrVideo.videoWidth) {
      ocrStatus.textContent = 'Kamera görüntüsü henüz hazır değil. Birkaç saniye sonra tekrar deneyin.';
      return;
    }
    ocrRead.disabled = true;
    try {
      const worker = await getOcrWorker();
      const frame = captureOcrFrame();
      // 1. deneme: kontrastı gerilmiş gri ton — eşiklemeyi Tesseract'ın kendi Otsu'suna bırak
      let result = await worker.recognize(paintOcrFrame(frame));
      let serial = normalizeSerial(result.data.text);
      if (!serial) {
        // 2. deneme: Otsu ile siyah/beyaz; koyu zemin üstüne açık yazı (kazınmış kasa
        // etiketi gibi) ise ters çevir — Tesseract açık zeminde koyu yazı bekler
        ocrStatus.textContent = 'Tekrar deneniyor...';
        const t = otsuThreshold(frame);
        let dark = 0;
        for (let j = 0; j < frame.total; j++) if (frame.gray[j] <= t) dark++;
        const invert = dark > frame.total / 2;
        result = await worker.recognize(paintOcrFrame(frame, g => {
          const bin = g > t ? 255 : 0;
          return invert ? 255 - bin : bin;
        }));
        serial = normalizeSerial(result.data.text);
      }
      if (serial) {
        oldSerialInput.value = serial;
        oldSerialInput.focus();
        oldSerialInput.select();
        ocrStatus.textContent = 'Okunan değer Eski PC Seri No alanına yazıldı. Kaydetmeden önce kontrol edin.';
        if (navigator.vibrate) navigator.vibrate(100);
        setTimeout(stopOcr, 1200);
      } else {
        ocrStatus.textContent = 'Seri numarası okunamadı. Daha yaklaşın, gerekirse ışığı (🔦) açın ve tekrar deneyin.';
        ocrRead.disabled = false;
      }
    } catch (err) {
      ocrStatus.textContent = 'OCR hatası: ' + (err.message || err);
      ocrRead.disabled = false;
    }
  });

  ocrTorch.addEventListener('click', async () => {
    if (!ocrStream) return;
    const track = ocrStream.getVideoTracks()[0];
    const on = ocrTorch.dataset.on === '1';
    try {
      await track.applyConstraints({ advanced: [{ torch: !on }] });
      ocrTorch.dataset.on = on ? '0' : '1';
    } catch (err) {
      ocrStatus.textContent = 'Işık açılamadı: ' + (err.message || err);
    }
  });

  ocrCancel.addEventListener('click', stopOcr);
</script>
<%- include('layout-bottom') %>
