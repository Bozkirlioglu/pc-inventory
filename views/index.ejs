<%- include('layout-top') %>
<div class="card card-narrow">
  <h1>Yeni Kurulum Kaydı</h1>
  <form method="post" action="/kayit">
    <label>Kullanıcı <% if (rules.personnel_id.required) { %><span class="req">*</span><% } %>
      <input list="personnel-list" id="personnel-search" placeholder="İsim yazarak arayın..."
             autocomplete="off" <% if (rules.personnel_id.required) { %>required<% } %>>
      <datalist id="personnel-list">
        <% personnel.forEach(p => { %>
          <option data-id="<%= p.id %>" data-newpcname="<%= p.new_pc_name || '' %>"
                  data-oldpcname="<%= p.old_pc_name || '' %>" data-department="<%= p.department || '' %>"
                  data-oldserial="<%= p.old_pc_serial || '' %>"
                  data-todo="<%= p.todo || '' %>" data-notes="<%= p.notes || '' %>"
                  data-desktop="<%= p.desktop %>" data-newserial="<%= p.new_pc_serial || '' %>"
                  value="<%= p.seq_no %> - <%= p.full_name %>"></option>
        <% }) %>
      </datalist>
      <input type="hidden" name="personnel_id" id="personnel-id">
    </label>
    <label>Yeni PC Adı
      <input id="new-pcname" readonly placeholder="Kullanıcı seçince otomatik dolar" class="readonly">
    </label>
    <label>Yeni PC Seri No <% if (rules.new_pc_serial.required) { %><span class="req">*</span><% } %>
      <div class="input-with-btn">
        <input name="new_pc_serial" id="new-serial" placeholder="Elle girin veya okutun"
               style="text-transform: uppercase" <% if (rules.new_pc_serial.required) { %>required<% } %>>
        <button type="button" class="scan-btn" data-target="new-serial" title="Barkod okut">📷 Okut</button>
        <button type="button" id="barcode-photo" title="Zor barkodlar için: fotoğraf çekip çöz">🖼️ Foto</button>
      </div>
    </label>
    <input type="file" id="barcode-file" accept="image/*" capture="environment" hidden>
    <label>Eski PC Adı
      <input name="old_pc_name" id="old-pcname" placeholder="Kullanıcı seçince dolar, düzenlenebilir">
    </label>
    <label>Eski PC Seri No <% if (rules.old_pc_serial.required) { %><span class="req">*</span><% } %>
      <div class="input-with-btn">
        <input name="old_pc_serial" id="old-serial" placeholder="Elle girin veya metin okuyun"
               style="text-transform: uppercase" <% if (rules.old_pc_serial.required) { %>required<% } %>>
        <button type="button" id="ocr-start" title="Kameradan metin oku">📷 Metin Oku</button>
      </div>
    </label>
    <input type="file" id="ocr-file" accept="image/*" capture="environment" hidden>
    <label>Departman
      <input name="department" id="department" placeholder="Kullanıcı seçince dolar, düzenlenebilir">
    </label>
    <div id="scanner-box" hidden>
      <p class="muted center" id="scan-target-label"></p>
      <div id="scanner"></div>
      <div id="scan-controls" class="scan-controls" hidden>
        <button type="button" id="scan-torch" class="btn-secondary" hidden>🔦 Işık</button>
        <label id="scan-zoom-wrap" class="scan-zoom" hidden>🔍
          <input type="range" id="scan-zoom" min="1" max="5" step="0.1" value="1">
        </label>
      </div>
      <p class="muted center" id="scan-status">Kamera başlatılıyor...</p>
      <button type="button" id="scan-cancel" class="btn-secondary btn-block">İptal</button>
    </div>
    <div id="ocr-box" hidden>
      <p class="muted center" id="ocr-status"></p>
      <div id="ocr-candidates"></div>
      <canvas id="ocr-canvas" hidden></canvas>
      <div class="action-row">
        <button type="button" id="ocr-retake" class="btn-secondary">📷 Tekrar Çek</button>
        <button type="button" id="ocr-cancel" class="btn-secondary">Kapat</button>
      </div>
    </div>
    <div id="photo-editor" hidden>
      <p class="muted center" id="pe-hint"></p>
      <div id="pe-viewport"><canvas id="pe-canvas"></canvas></div>
      <div class="scan-controls">
        <button type="button" id="pe-rot-left" class="btn-secondary" title="Sola döndür">⟲ Döndür</button>
        <label class="scan-zoom">🔍
          <input type="range" id="pe-zoom" min="1" max="6" step="0.05" value="1">
        </label>
        <button type="button" id="pe-rot-right" class="btn-secondary" title="Sağa döndür">Döndür ⟳</button>
      </div>
      <div class="action-row">
        <button type="button" id="pe-confirm">Kullan</button>
        <button type="button" id="pe-retake" class="btn-secondary">📷 Tekrar Çek</button>
        <button type="button" id="pe-cancel" class="btn-secondary">İptal</button>
      </div>
    </div>
    <fieldset class="device-type">
      <legend>Cihaz Tipi</legend>
      <label class="radio-inline"><input type="radio" name="desktop" value="D"> Desktop</label>
      <label class="radio-inline"><input type="radio" name="desktop" value="N"> Notebook</label>
      <label class="radio-inline"><input type="radio" name="desktop" value="V" checked> VDI</label>
      <label class="radio-inline"><input type="radio" name="desktop" value="W"> Workgroup</label>
    </fieldset>
    <label>#TODO <% if (rules.todo && rules.todo.required) { %><span class="req">*</span><% } else { %><small>(opsiyonel)</small><% } %>
      <textarea name="todo" id="todo" rows="3" placeholder="Yapılacaklar..." <% if (rules.todo && rules.todo.required) { %>required<% } %>></textarea>
    </label>
    <label>Not <% if (rules.notes.required) { %><span class="req">*</span><% } else { %><small>(opsiyonel)</small><% } %>
      <input name="notes" id="notes" placeholder="Ek bilgi..." <% if (rules.notes.required) { %>required<% } %>>
    </label>
    <button type="submit">Kaydet</button>
  </form>
  <% if (personnel.length === 0) { %>
    <p class="muted">Henüz personel listesi yüklenmemiş. <% if (user.role === 'admin') { %><a href="/admin">Yönetim</a> sayfasından CSV import edin.<% } else { %>Yöneticinizle iletişime geçin.<% } %></p>
  <% } %>
</div>
<script src="/vendor/html5-qrcode/html5-qrcode.min.js"></script>
<script src="/vendor/tesseract.js/dist/tesseract.min.js"></script>
<script>
  const search = document.getElementById('personnel-search');
  const hiddenId = document.getElementById('personnel-id');
  const newPcName = document.getElementById('new-pcname');
  const oldPcName = document.getElementById('old-pcname');
  const departmentInput = document.getElementById('department');
  const oldSerialInput = document.getElementById('old-serial');
  const newSerialInput = document.getElementById('new-serial');
  const todoInput = document.getElementById('todo');
  const notesInput = document.getElementById('notes');
  const deviceRadios = document.querySelectorAll('input[name="desktop"]');
  const formCard = document.querySelector('.card');
  const options = document.querySelectorAll('#personnel-list option');

  // Cihaz tipine göre arka plan: Desktop yeşil, Notebook camgöbeği, Workgroup turuncu, VDI beyaz
  const DEVICE_BG = { D: '#77DD77', N: '#24ffff', V: '', W: '#fc7b03' };
  function currentDevice() {
    const r = document.querySelector('input[name="desktop"]:checked');
    return r ? r.value : 'N';
  }
  function setDevice(code) {
    deviceRadios.forEach(r => { r.checked = (r.value === code); });
  }
  function updateDeviceBg() {
    const bg = DEVICE_BG[currentDevice()] || '';
    document.body.style.background = bg;
    formCard.style.background = bg;
  }
  deviceRadios.forEach(r => r.addEventListener('change', updateDeviceBg));

  // Yeni PC seri no doluysa alanı mat kırmızı kutuya al (dolu olduğunu vurgular)
  function updateNewSerialBox() {
    newSerialInput.classList.toggle('serial-filled', newSerialInput.value.trim() !== '');
  }
  newSerialInput.addEventListener('input', updateNewSerialBox);

  search.addEventListener('input', () => {
    hiddenId.value = '';
    newPcName.value = '';
    oldPcName.value = '';
    departmentInput.value = '';
    oldSerialInput.value = '';
    newSerialInput.value = '';
    todoInput.value = '';
    notesInput.value = '';
    for (const opt of options) {
      if (opt.value === search.value) {
        hiddenId.value = opt.dataset.id;
        newPcName.value = opt.dataset.newpcname;
        // Personelle önceden yüklenmiş alanlar formu doldurur (düzenlenebilir)
        oldPcName.value = opt.dataset.oldpcname || '';
        departmentInput.value = opt.dataset.department || '';
        todoInput.value = opt.dataset.todo || '';
        notesInput.value = opt.dataset.notes || '';
        setDevice(opt.dataset.desktop || 'N');
        updateDeviceBg();
        if (opt.dataset.oldserial) oldSerialInput.value = opt.dataset.oldserial;
        if (opt.dataset.newserial) newSerialInput.value = opt.dataset.newserial;
        break;
      }
    }
    updateNewSerialBox();
  });

  document.querySelector('form').addEventListener('submit', e => {
    // Kullanıcı alanına bir şey yazılmış ama listeden eşleşmemişse engelle;
    // boş bırakmak (kural zorunlu demiyorsa) serbest.
    if (search.value.trim() && !hiddenId.value) {
      e.preventDefault();
      alert('Lütfen listeden geçerli bir kullanıcı seçin veya alanı boş bırakın.');
    }
  });

  // --- Barkod okuma (cep telefonu kamerası) — hedef alana yazar ---
  const scannerBox = document.getElementById('scanner-box');
  const scanStatus = document.getElementById('scan-status');
  const scanTargetLabel = document.getElementById('scan-target-label');
  const scanButtons = document.querySelectorAll('.scan-btn');
  const scanControls = document.getElementById('scan-controls');
  const scanTorch = document.getElementById('scan-torch');
  const scanZoomWrap = document.getElementById('scan-zoom-wrap');
  const scanZoom = document.getElementById('scan-zoom');
  const BARCODE_FORMATS = typeof Html5QrcodeSupportedFormats !== 'undefined' ? [
    Html5QrcodeSupportedFormats.CODE_128,
    Html5QrcodeSupportedFormats.CODE_39,
    Html5QrcodeSupportedFormats.CODE_93,
    Html5QrcodeSupportedFormats.EAN_13,
    Html5QrcodeSupportedFormats.EAN_8,
    Html5QrcodeSupportedFormats.UPC_A,
    Html5QrcodeSupportedFormats.UPC_E,
    Html5QrcodeSupportedFormats.ITF,
    Html5QrcodeSupportedFormats.QR_CODE,
    Html5QrcodeSupportedFormats.DATA_MATRIX
  ] : [];
  let scanner = null;

  function resetScanControls() {
    scanControls.hidden = true;
    scanTorch.hidden = true;
    scanZoomWrap.hidden = true;
    scanTorch.onclick = null;
    scanZoom.oninput = null;
  }

  // Canlı tarayıcı başladıktan sonra cihaz destekliyorsa ışık (fener) ve
  // yakınlaştırma denetimlerini bağla — barkoda zoom yapmak netlemeyi hızlandırır.
  function setupScanControls() {
    let caps;
    try { caps = scanner.getRunningTrackCameraCapabilities(); } catch (e) { return; }
    // Sürekli otofokus (destekleyen cihazlarda; desteklenmezse sessiz geç)
    try { Promise.resolve(scanner.applyVideoConstraints({ advanced: [{ focusMode: 'continuous' }] })).catch(() => {}); } catch (e) {}
    let any = false;
    try {
      const zoom = caps.zoomFeature();
      if (zoom && zoom.isSupported()) {
        scanZoom.min = zoom.min();
        scanZoom.max = zoom.max();
        scanZoom.step = zoom.step() || 0.1;
        scanZoom.value = zoom.value();
        scanZoom.oninput = () => { try { zoom.apply(Number(scanZoom.value)); } catch (e) {} };
        scanZoomWrap.hidden = false;
        any = true;
      }
    } catch (e) {}
    try {
      const torch = caps.torchFeature();
      if (torch && torch.isSupported()) {
        let on = false;
        const label = () => { scanTorch.textContent = on ? '🔦 Işık ✓' : '🔦 Işık'; };
        label();
        scanTorch.onclick = async () => {
          try { on = !on; await torch.apply(on); label(); } catch (e) {}
        };
        scanTorch.hidden = false;
        any = true;
      }
    } catch (e) {}
    scanControls.hidden = !any;
  }

  async function stopScanner() {
    if (scanner) {
      try { await scanner.stop(); scanner.clear(); } catch (e) {}
      scanner = null;
    }
    resetScanControls();
    scannerBox.hidden = true;
    scanButtons.forEach(b => b.disabled = false);
    const bf = document.getElementById('barcode-file');
    if (bf) bf.hidden = true; // İptal ile kapatınca fotoğraf yedeği de gizlensin
  }

  scanButtons.forEach(btn => btn.addEventListener('click', async () => {
    if (!window.isSecureContext) {
      alert('Kamera yalnızca HTTPS (güvenli bağlantı) üzerinden kullanılabilir.');
      return;
    }
    if (typeof Html5Qrcode === 'undefined') {
      alert('Barkod kütüphanesi yüklenemedi.');
      return;
    }
    await stopScanner(); // önceki oturum açıksa kapat
    const target = document.getElementById(btn.dataset.target);
    scanButtons.forEach(b => b.disabled = true);
    scannerBox.hidden = false;
    scanTargetLabel.textContent = btn.closest('label') ? btn.closest('label').textContent.trim().split('\n')[0] : '';
    scanStatus.textContent = 'Kamera başlatılıyor...';

    scanner = new Html5Qrcode('scanner', { formatsToSupport: BARCODE_FORMATS });

    try {
      await scanner.start(
        { facingMode: 'environment' }, // arka kamera
        { fps: 10, qrbox: { width: 280, height: 140 } }, // yatay kutu: 1D barkod için
        decoded => {
          target.value = decoded.trim().toUpperCase();
          if (target === newSerialInput) updateNewSerialBox();
          if (navigator.vibrate) navigator.vibrate(100);
          stopScanner();
        },
        () => {} // kare başına okunamama normal, sessiz geç
      );
      scanStatus.textContent = 'Barkodu çerçeveye hizalayın';
      setupScanControls();
    } catch (err) {
      scanStatus.textContent = 'Kamera açılamadı: ' + (err.message || err);
      scanButtons.forEach(b => b.disabled = false);
    }
  }));

  document.getElementById('scan-cancel').addEventListener('click', stopScanner);

  // --- Zor barkodlar için yedek: telefonun kamera uygulamasıyla fotoğraf çekip çöz ---
  // Canlı tarayıcı tutmadığında (yıpranmış/loş/küçük barkod) native kameranın
  // netleme ve flaşıyla çekilen tek kare çoğu zaman kurtarır.
  const barcodePhotoBtn = document.getElementById('barcode-photo');
  const barcodeFile = document.getElementById('barcode-file');

  barcodePhotoBtn.addEventListener('click', async () => {
    if (typeof Html5Qrcode === 'undefined') {
      alert('Barkod kütüphanesi yüklenemedi.');
      return;
    }
    await stopScanner();
    barcodeFile.value = '';
    barcodeFile.hidden = false; // otomatik dialog açılmazsa görünür Dosya Seç yedek olur
    barcodeFile.click(); // telefonun kendi kamera uygulamasını açar
  });

  barcodeFile.addEventListener('change', async () => {
    const file = barcodeFile.files && barcodeFile.files[0];
    barcodeFile.value = ''; // aynı dosya yeniden seçilebilsin diye sıfırla
    barcodeFile.hidden = true;
    if (!file) return;
    await openEditor(file,
      'Barkodu çerçeveye alıp yakınlaştırın; yamuksa döndürüp yatay yapın, sonra “Kullan”.',
      decodeBarcodeFromCanvas,
      () => { barcodeFile.hidden = false; barcodeFile.click(); });
  });

  // Editörde çerçevelenmiş kareyi barkod olarak çöz; bulunamazsa editörü açık
  // bırak ki kullanıcı yeniden yakınlaştırıp döndürerek tekrar deneyebilsin.
  async function decodeBarcodeFromCanvas(canvas) {
    peConfirmBtn.disabled = true;
    peHint.textContent = 'Barkod çözülüyor...';
    const blob = await new Promise(res => canvas.toBlob(res, 'image/png'));
    const f = new File([blob], 'crop.png', { type: 'image/png' });
    const fileScanner = new Html5Qrcode('scanner', { formatsToSupport: BARCODE_FORMATS });
    try {
      const decoded = await fileScanner.scanFile(f, /* showImage */ false);
      newSerialInput.value = decoded.trim().toUpperCase();
      updateNewSerialBox();
      if (navigator.vibrate) navigator.vibrate(100);
      closeEditor();
    } catch (err) {
      peHint.textContent = 'Barkod bulunamadı. Barkodu çerçeveye alıp yakınlaştırın, yatay hale getirip tekrar “Kullan”a basın.';
    } finally {
      try { fileScanner.clear(); } catch (e) {}
      peConfirmBtn.disabled = false;
    }
  }

  // --- Eski seri no için OCR: telefonun kamera uygulamasıyla çekilen fotoğraftan okuma ---
  // Canlı video karesi yerine native kamera fotoğrafı kullanılır: netleme/HDR çok daha iyi,
  // HTTPS gerektirmez ve tam sensör çözünürlüğü gelir.
  const ocrBox = document.getElementById('ocr-box');
  const ocrStatus = document.getElementById('ocr-status');
  const ocrCanvas = document.getElementById('ocr-canvas');
  const ocrCandidates = document.getElementById('ocr-candidates');
  const ocrStart = document.getElementById('ocr-start');
  const ocrFile = document.getElementById('ocr-file');
  const ocrRetake = document.getElementById('ocr-retake');
  const ocrCancel = document.getElementById('ocr-cancel');
  let ocrWorker = null;
  let ocrBusy = false;

  function closeOcr() {
    ocrBox.hidden = true;
    ocrCandidates.innerHTML = '';
    ocrFile.value = '';
    ocrFile.hidden = true;
  }

  function useSerial(value) {
    oldSerialInput.value = value;
    oldSerialInput.focus();
    if (navigator.vibrate) navigator.vibrate(100);
    closeOcr();
  }

  // Etikette seri dışında da çok metin olur (model adı, parça no, uyarılar...);
  // bilinen kelimeleri ele, rakam içeren 4-20 karakterlik parçaları aday yap.
  const OCR_STOPWORDS = new Set(['SERVICE', 'SERIAL', 'NUMBER', 'MODEL', 'MADE', 'CHINA', 'VIETNAM',
    'ASSEMBLED', 'PRODUCT', 'WINDOWS', 'RATING', 'INPUT', 'OUTPUT', 'LISTED', 'WARRANTY', 'REGULATORY',
    'LATITUDE', 'OPTIPLEX', 'VOSTRO', 'INSPIRON', 'PRECISION', 'THINKPAD', 'THINKCENTRE', 'IDEAPAD',
    'ELITEBOOK', 'PROBOOK', 'PRODESK', 'ELITEDESK', 'PAVILION', 'TRAVELMATE', 'ASPIRE', 'EXTENSA']);

  function extractCandidates(text) {
    const up = String(text || '').toUpperCase();
    // "S/N ABC1234" gibi anahtar kelimenin hemen ardından gelen değer en güçlü aday
    const keyed = up.match(/\b(?:S\/N|SN|SERIAL\s*(?:NO|NUMBER)?|SERVICE\s*TAG|SERI\s*NO)\b[:#\s]*([A-Z0-9][A-Z0-9\-_/]{3,})/);
    const tokens = up.split(/\s+/)
      .map(t => t.replace(/[^A-Z0-9\-_/]/g, ''))
      .filter(t => t.length >= 4 && t.length <= 20 && !OCR_STOPWORDS.has(t));
    const withDigit = tokens.filter(t => /[0-9]/.test(t));
    const pool = withDigit.length ? withDigit : tokens; // tamamı harf olan seriler için geri düşüş
    // Seri numaraları çoğunlukla 6-12 karakter — o aralığa yakın olanları öne al
    pool.sort((a, b) => Math.abs(a.length - 9) - Math.abs(b.length - 9));
    const seen = new Set();
    const out = [];
    if (keyed && keyed[1] && !OCR_STOPWORDS.has(keyed[1])) { seen.add(keyed[1]); out.push(keyed[1]); }
    for (const t of pool) {
      if (!seen.has(t)) { seen.add(t); out.push(t); }
      if (out.length >= 6) break;
    }
    return out;
  }

  function showCandidates(list) {
    ocrCandidates.innerHTML = '';
    list.forEach(value => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'ocr-candidate';
      b.textContent = value;
      b.addEventListener('click', () => useSerial(value));
      ocrCandidates.appendChild(b);
    });
  }

  function histPercentile(hist, total, p) {
    const target = total * p;
    let cum = 0;
    for (let i = 0; i < 256; i++) {
      cum += hist[i];
      if (cum >= target) return i;
    }
    return 255;
  }

  // Fotoğrafı en fazla ~2200 px olacak şekilde küçültür, gri tona çevirir ve
  // %1-%99 persentil aralığına kontrast gerer (tek parlama noktası germeyi bozmasın diye min/max değil).
  async function photoToFrame(src) {
    // src: File (kamera) veya editörden gelen canvas/ImageBitmap olabilir
    let bmp;
    if (typeof ImageBitmap !== 'undefined' && src instanceof ImageBitmap) {
      bmp = src;
    } else {
      try {
        bmp = await createImageBitmap(src, { imageOrientation: 'from-image' }); // EXIF dönüşünü uygula
      } catch (e) {
        bmp = await createImageBitmap(src); // eski tarayıcılar seçenek nesnesini desteklemeyebilir
      }
    }
    const ratio = Math.min(1, 2200 / Math.max(bmp.width, bmp.height));
    ocrCanvas.width = Math.round(bmp.width * ratio);
    ocrCanvas.height = Math.round(bmp.height * ratio);
    const ctx = ocrCanvas.getContext('2d', { willReadFrequently: true });
    ctx.drawImage(bmp, 0, 0, ocrCanvas.width, ocrCanvas.height);
    bmp.close();

    const image = ctx.getImageData(0, 0, ocrCanvas.width, ocrCanvas.height);
    const total = ocrCanvas.width * ocrCanvas.height;
    const gray = new Uint8ClampedArray(total);
    const hist = new Uint32Array(256);
    for (let i = 0, j = 0; j < total; i += 4, j++) {
      const g = Math.round(image.data[i] * 0.299 + image.data[i + 1] * 0.587 + image.data[i + 2] * 0.114);
      gray[j] = g;
      hist[g]++;
    }
    const lo = histPercentile(hist, total, 0.01);
    const hi = Math.max(lo + 1, histPercentile(hist, total, 0.99));
    for (let j = 0; j < total; j++) {
      gray[j] = (gray[j] - lo) * 255 / (hi - lo); // Uint8ClampedArray 0-255'e kırpar
    }
    return { ctx, image, gray, total };
  }

  // Gri değerleri (istenirse bir dönüşümden geçirip) canvas'a basar, canvas'ı döndürür.
  function paintOcrFrame(frame, transform) {
    for (let j = 0, i = 0; j < frame.total; j++, i += 4) {
      const v = transform ? transform(frame.gray[j]) : frame.gray[j];
      frame.image.data[i] = v;
      frame.image.data[i + 1] = v;
      frame.image.data[i + 2] = v;
    }
    frame.ctx.putImageData(frame.image, 0, 0);
    return ocrCanvas;
  }

  // Otsu eşiği: sınıflar arası varyansı maksimize eden gri değer
  function otsuThreshold(frame) {
    const hist = new Uint32Array(256);
    for (let j = 0; j < frame.total; j++) hist[frame.gray[j]]++;
    let sum = 0;
    for (let i = 0; i < 256; i++) sum += i * hist[i];
    let sumB = 0, wB = 0, maxVar = 0, threshold = 127;
    for (let i = 0; i < 256; i++) {
      wB += hist[i];
      if (!wB) continue;
      const wF = frame.total - wB;
      if (!wF) break;
      sumB += i * hist[i];
      const mB = sumB / wB, mF = (sum - sumB) / wF;
      const between = wB * wF * (mB - mF) * (mB - mF);
      if (between > maxVar) { maxVar = between; threshold = i; }
    }
    return threshold;
  }

  async function getOcrWorker() {
    if (ocrWorker) return ocrWorker;
    ocrStatus.textContent = 'OCR motoru hazırlanıyor...';
    ocrWorker = await Tesseract.createWorker('eng', 1, {
      workerPath: '/vendor/tesseract.js/dist/worker.min.js',
      corePath: '/vendor/tesseract-core',
      langPath: '/vendor/tessdata/4.0.0/',
      logger: message => {
        if (message.status === 'recognizing text') {
          ocrStatus.textContent = `Metin okunuyor... %${Math.round(message.progress * 100)}`;
        }
      }
    });
    await ocrWorker.setParameters({
      tessedit_char_whitelist: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_/ ',
      tessedit_pageseg_mode: Tesseract.PSM.SPARSE_TEXT, // etikette dağınık kısa metinler var
      preserve_interword_spaces: '1'
    });
    return ocrWorker;
  }

  ocrStart.addEventListener('click', async () => {
    if (typeof Tesseract === 'undefined') {
      alert('OCR kütüphanesi yüklenemedi.');
      return;
    }
    await stopScanner();
    ocrFile.value = '';
    ocrFile.hidden = false; // otomatik dialog açılmazsa görünür Dosya Seç yedek olur
    ocrFile.click(); // telefonun kendi kamera uygulamasını açar
  });

  ocrFile.addEventListener('change', async () => {
    const file = ocrFile.files && ocrFile.files[0];
    ocrFile.value = ''; // aynı dosya yeniden seçilebilsin diye sıfırla
    ocrFile.hidden = true;
    if (!file) return;
    await openEditor(file,
      'Etiketi çerçeveye alıp yakınlaştırın; yazı yatay olacak şekilde döndürün, sonra “Kullan”.',
      canvas => { closeEditor(); runOcr(canvas); },
      () => { ocrFile.hidden = false; ocrFile.click(); });
  });

  async function runOcr(source) {
    if (ocrBusy) return;
    ocrBusy = true;
    ocrBox.hidden = false;
    ocrCandidates.innerHTML = '';
    ocrRetake.disabled = true;
    ocrStatus.textContent = 'Fotoğraf işleniyor...';
    try {
      const frame = await photoToFrame(source);
      const worker = await getOcrWorker();
      // 1. deneme: kontrastı gerilmiş gri ton — eşiklemeyi Tesseract'ın kendi Otsu'suna bırak
      let result = await worker.recognize(paintOcrFrame(frame));
      let candidates = extractCandidates(result.data.text);
      if (!candidates.length) {
        // 2. deneme: Otsu ile siyah/beyaz; koyu zemin üstüne açık yazı (kazınmış kasa
        // etiketi gibi) ise ters çevir — Tesseract açık zeminde koyu yazı bekler
        ocrStatus.textContent = 'Tekrar deneniyor...';
        const t = otsuThreshold(frame);
        let dark = 0;
        for (let j = 0; j < frame.total; j++) if (frame.gray[j] <= t) dark++;
        const invert = dark > frame.total / 2;
        result = await worker.recognize(paintOcrFrame(frame, g => {
          const bin = g > t ? 255 : 0;
          return invert ? 255 - bin : bin;
        }));
        candidates = extractCandidates(result.data.text);
      }
      if (candidates.length === 1) {
        useSerial(candidates[0]);
      } else if (candidates.length) {
        showCandidates(candidates);
        ocrStatus.textContent = 'Okunan adaylardan seri numarasını seçin:';
      } else {
        ocrStatus.textContent = 'Seri numarası okunamadı. Etikete yaklaşıp yazı net ve yatay olacak şekilde yeniden çekin.';
      }
    } catch (err) {
      ocrStatus.textContent = 'OCR hatası: ' + (err.message || err);
    } finally {
      ocrBusy = false;
      ocrRetake.disabled = false;
    }
  }

  ocrRetake.addEventListener('click', () => { if (!ocrBusy) ocrFile.click(); });
  ocrCancel.addEventListener('click', closeOcr);

  // --- Ortak fotoğraf editörü: çekilen kareyi yakınlaştır/döndür, sonra çöz ---
  // Hem barkod fotoğrafı (yeni seri) hem OCR (eski seri) bu editörden geçer.
  // Barkodu/etiketi çerçeveye alıp yatay hale getirmek okuma başarısını ciddi artırır;
  // native kamera tek net kare çektiği için canlı otofokusla boğuşmak da gerekmez.
  const photoEditor = document.getElementById('photo-editor');
  const peCanvas = document.getElementById('pe-canvas');
  const peZoom = document.getElementById('pe-zoom');
  const peHint = document.getElementById('pe-hint');
  const peConfirmBtn = document.getElementById('pe-confirm');
  const PE_W = 2048, PE_H = 1536; // iç çözünürlük (4:3) — yatay barkodlara uygun
  const peCtx = peCanvas.getContext('2d');
  let peImg = null, peRot = 0, peScale = 1, panX = 0, panY = 0;
  let peConfirmCb = null, peRetakeCb = null;

  function peBaseScale() {
    const rw = (peRot % 180 === 0) ? peImg.width : peImg.height;
    const rh = (peRot % 180 === 0) ? peImg.height : peImg.width;
    return Math.min(PE_W / rw, PE_H / rh);
  }

  function peRender() {
    if (!peImg) return;
    const eff = peBaseScale() * peScale;
    peCtx.setTransform(1, 0, 0, 1, 0, 0);
    peCtx.fillStyle = '#000';
    peCtx.fillRect(0, 0, PE_W, PE_H);
    peCtx.imageSmoothingQuality = 'high';
    peCtx.translate(PE_W / 2 + panX, PE_H / 2 + panY);
    peCtx.rotate(peRot * Math.PI / 180);
    peCtx.scale(eff, eff);
    peCtx.drawImage(peImg, -peImg.width / 2, -peImg.height / 2);
  }

  async function openEditor(file, hint, onConfirm, onRetake) {
    if (peImg) { try { peImg.close(); } catch (e) {} peImg = null; }
    try {
      peImg = await createImageBitmap(file, { imageOrientation: 'from-image' });
    } catch (e) {
      peImg = await createImageBitmap(file);
    }
    peCanvas.width = PE_W;
    peCanvas.height = PE_H;
    peRot = 0; peScale = 1; panX = 0; panY = 0;
    peZoom.value = 1;
    peHint.textContent = hint || '';
    peConfirmBtn.disabled = false;
    peConfirmCb = onConfirm;
    peRetakeCb = onRetake;
    photoEditor.hidden = false;
    peRender();
  }

  function closeEditor() {
    photoEditor.hidden = true;
    if (peImg) { try { peImg.close(); } catch (e) {} peImg = null; }
    peConfirmCb = null;
    peRetakeCb = null;
  }

  peZoom.addEventListener('input', () => { peScale = Number(peZoom.value); peRender(); });
  document.getElementById('pe-rot-left').addEventListener('click', () => { peRot = (peRot + 270) % 360; panX = 0; panY = 0; peRender(); });
  document.getElementById('pe-rot-right').addEventListener('click', () => { peRot = (peRot + 90) % 360; panX = 0; panY = 0; peRender(); });
  document.getElementById('pe-cancel').addEventListener('click', closeEditor);
  document.getElementById('pe-retake').addEventListener('click', () => { const cb = peRetakeCb; closeEditor(); if (cb) cb(); });
  peConfirmBtn.addEventListener('click', () => { if (peConfirmCb) peConfirmCb(peCanvas); });

  // Tek parmak: kaydır. İki parmak: yakınlaştır (slider yedek olarak her cihazda çalışır).
  const pePointers = new Map();
  let pePinchDist = 0, pePinchScale = 1;
  peCanvas.addEventListener('pointerdown', e => {
    try { peCanvas.setPointerCapture(e.pointerId); } catch (err) {}
    pePointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
    if (pePointers.size === 2) {
      const pts = [...pePointers.values()];
      pePinchDist = Math.hypot(pts[0].x - pts[1].x, pts[0].y - pts[1].y);
      pePinchScale = peScale;
    }
  });
  peCanvas.addEventListener('pointermove', e => {
    const p = pePointers.get(e.pointerId);
    if (!p) return;
    const rect = peCanvas.getBoundingClientRect();
    const toCanvas = rect.width ? PE_W / rect.width : 1; // ekran px -> iç canvas px
    if (pePointers.size === 1) {
      panX += (e.clientX - p.x) * toCanvas;
      panY += (e.clientY - p.y) * toCanvas;
      p.x = e.clientX; p.y = e.clientY;
      peRender();
    } else if (pePointers.size === 2) {
      p.x = e.clientX; p.y = e.clientY;
      const pts = [...pePointers.values()];
      const dist = Math.hypot(pts[0].x - pts[1].x, pts[0].y - pts[1].y);
      if (pePinchDist > 0) {
        peScale = Math.min(6, Math.max(1, pePinchScale * dist / pePinchDist));
        peZoom.value = peScale;
        peRender();
      }
    }
  });
  function pePointerEnd(e) {
    pePointers.delete(e.pointerId);
    if (pePointers.size < 2) pePinchDist = 0;
  }
  peCanvas.addEventListener('pointerup', pePointerEnd);
  peCanvas.addEventListener('pointercancel', pePointerEnd);
</script>
