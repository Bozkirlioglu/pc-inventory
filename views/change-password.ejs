<%- include('layout-top') %>
<div class="card card-narrow">
  <h1>Şifre Değiştir</h1>
  <% if (error) { %><div class="flash flash-error"><%= error %></div><% } %>
  <form method="post" action="/sifre-degistir">
    <label>Mevcut şifre
      <input type="password" name="current" required autocomplete="current-password">
    </label>
    <label>Yeni şifre <small>(en az 8 karakter)</small>
      <input type="password" name="newpass" required minlength="8" autocomplete="new-password">
    </label>
    <label>Yeni şifre (tekrar)
      <input type="password" name="newpass2" required minlength="8" autocomplete="new-password">
    </label>
    <button type="submit">Güncelle</button>
  </form>
</div>
<%- include('layout-bottom') %>
