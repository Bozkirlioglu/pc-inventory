# Bu dosyayi .env olarak kopyalayip degerleri doldurun

# MySQL baglantisi
DB_HOST=localhost
DB_PORT=3306
DB_USER=pc_envanter
DB_PASSWORD=guclu-bir-sifre
DB_NAME=pc_envanter

# Oturum imzalama anahtari — rastgele uzun bir deger girin
SESSION_SECRET=rastgele-uzun-bir-anahtar-yazin

# Ilk calistirmada olusturulacak admin sifresi (bos birakilirsa: admin123)
ADMIN_PASSWORD=

# Uygulama portu
PORT=3000

# Canli ortamda (HTTPS arkasinda) acin — secure cookie icin gerekli
# NODE_ENV=production
